# /etc/goldfish-cron.env 範本
# goldfish-daily.sh 會 source 此檔取得 JOBS_TOKEN（daily reminder 的 Bearer token）
#
# 部署到 VM 後手動建立真實檔（內含 secret 不進版控）：
#   sudo nano /etc/goldfish-cron.env     # 填入與 appsettings.Production.json 的 Jobs:AuthToken 相同的值
#   sudo chmod 600 /etc/goldfish-cron.env
JOBS_TOKEN=__REPLACE_WITH_REAL_TOKEN__
