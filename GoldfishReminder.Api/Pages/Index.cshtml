        <div class="modal-content border-0 shadow-soft" style="border-radius: 14px;">
            <div class="modal-header">
                <h5 class="modal-title" id="creditSettingModalLabel">信用卡設定</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="creditSettingForm" method="post" asp-page="/Index" asp-page-handler="UpsertCreditSetting">
