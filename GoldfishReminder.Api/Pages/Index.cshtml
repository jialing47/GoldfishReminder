<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js" defer></script>
<script>
    // 設定中心預覽 tab 切換 + 三個 modal 假資料填入
    document.addEventListener('DOMContentLoaded', function ()
    {
        // tab 名稱對應 panel id
        var tabMap = {
            'bankAccounts': 'previewPanelBankAccounts',
            'creditSettings': 'previewPanelCreditSettings',
            'currentBills': 'previewPanelCurrentBills',
            'historyBills': 'previewPanelHistoryBills'
        };

        // 綁定 tab 按鈕點擊
        var tabButtons = document.querySelectorAll('[data-preview-tab]');
        for (var i = 0; i < tabButtons.length; i++)
        {
            tabButtons[i].addEventListener('click', function ()
            {
                for (var j = 0; j < tabButtons.length; j++)
                {
                    tabButtons[j].classList.remove('active');
                }
                this.classList.add('active');

                var panels = document.querySelectorAll('.gf-preview-panel');
                for (var k = 0; k < panels.length; k++)
                {
                    panels[k].classList.add('d-none');
                }
                var targetId = tabMap[this.getAttribute('data-preview-tab')];
                if (targetId)
                {
                    document.getElementById(targetId).classList.remove('d-none');
                }
            });
        }

        // 銀行帳戶 modal 填入假資料 + 待扣影響提示
        var bankModal = document.getElementById('previewBankModal');
        if (bankModal)
        {
            bankModal.addEventListener('show.bs.modal', function (event)
            {
                var button = event.relatedTarget;
                if (!button)
                {
                    return;
                }

                var bankCode = button.getAttribute('data-bankcode') || '';
                var bankName = button.getAttribute('data-bankname') || '';
                var isDisabled = button.getAttribute('data-disabled') === 'true';

                document.getElementById('pvBankCode').value = bankCode;
                document.getElementById('pvAccountName').value = button.getAttribute('data-accountname') || '';
                document.getElementById('pvAccountType').value = button.getAttribute('data-accounttype') || 'digital';
                document.getElementById('pvBalance').value = button.getAttribute('data-balance') || '';
                document.getElementById('pvEnabled').checked = !isDisabled;

                // 銀行名稱預覽
                var preview = document.getElementById('pvBankPreview');
                if (bankName)
                {
                    preview.textContent = bankName;
                    preview.className = 'gf-bank-preview is-hit';
                }
                else
                {
                    preview.textContent = '';
                    preview.className = 'gf-bank-preview';
                }

                // 待扣影響提示
                var impactBox = document.getElementById('pvImpactBox');
                var hasImpact = button.getAttribute('data-hasimpact') === 'true';
                if (hasImpact)
                {
                    var cardName = button.getAttribute('data-impactcard') || '';
                    var impactAmt = button.getAttribute('data-impactamt') || '0';
                    document.getElementById('pvImpactSummary').textContent = '此帳戶有 1 張信用卡設為自動扣款，合計待扣 ' + impactAmt;
                    document.getElementById('pvImpactDetails').innerHTML = '<li><span>' + cardName + '</span><span>−' + impactAmt + '</span></li>';
                    impactBox.classList.remove('d-none');
                }
                else
                {
                    impactBox.classList.add('d-none');
                }

                // 停用警告
                var disableWarning = document.getElementById('pvDisableWarning');
                disableWarning.classList.add('d-none');
            });

            // 啟用 checkbox 切換停用警告
            var enabledCheckbox = document.getElementById('pvEnabled');
            if (enabledCheckbox)
            {
                enabledCheckbox.addEventListener('change', function ()
                {
                    var disableWarning = document.getElementById('pvDisableWarning');
                    if (!this.checked)
                    {
                        disableWarning.classList.remove('d-none');
                    }
                    else
                    {
                        disableWarning.classList.add('d-none');
                    }
                });
            }
        }

        // 信用卡 modal 填入假資料
        var creditModal = document.getElementById('previewCreditModal');
        if (creditModal)
        {
            creditModal.addEventListener('show.bs.modal', function (event)
            {
                var button = event.relatedTarget;
                if (!button)
                {
                    return;
                }

                var bankCode = button.getAttribute('data-bankcode') || '';
                var bankName = button.getAttribute('data-bankname') || '';

                document.getElementById('pvCsBankCode').value = bankCode;
                document.getElementById('pvStatementDay').value = button.getAttribute('data-statementday') || '';
                document.getElementById('pvPaymentDueDay').value = button.getAttribute('data-paymentdueday') || '';
                document.getElementById('pvCsEnabled').checked = true;

                // 銀行名稱預覽
                var preview = document.getElementById('pvCsBankPreview');
                if (bankName)
                {
                    preview.textContent = bankName;
                    preview.className = 'gf-bank-preview is-hit';
                }
                else
                {
                    preview.textContent = '';
                    preview.className = 'gf-bank-preview';
                }

                // 扣款帳戶 select 對應
                var payAcct = button.getAttribute('data-payacct') || '';
                var selectEl = document.getElementById('pvPaymentAccountId');
                selectEl.value = '';
                for (var i = 0; i < selectEl.options.length; i++)
                {
                    if (selectEl.options[i].text.indexOf(payAcct) !== -1 && payAcct !== '')
                    {
                        selectEl.value = selectEl.options[i].value;
                        break;
                    }
                }
            });
        }

        // 帳單金額 modal 填入假資料
        var billModal = document.getElementById('previewBillModal');
        if (billModal)
        {
            billModal.addEventListener('show.bs.modal', function (event)
            {
                var button = event.relatedTarget;
                if (!button)
                {
                    return;
                }
                var amount = button.getAttribute('data-billamount') || '0';
                document.getElementById('pvBillAmount').value = amount;
            });
        }
    });
</script>

</body>
</html>
