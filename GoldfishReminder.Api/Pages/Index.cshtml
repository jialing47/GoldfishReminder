<div class="modal fade" id="billAmountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-soft" style="border-radius: 14px;">
            <div class="modal-header">
                <h5 class="modal-title" id="billAmountModalLabel">修改帳單金額</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="billAmountForm" method="post" asp-page="/Index" asp-page-handler="UpdateBillAmount">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="tab" value="currentBills" />
                    <input type="hidden" name="historyYear" value="@Model.HistoryYear" />
                    <input type="hidden" name="historyMonth" value="@Model.HistoryMonth" />
                    <input type="hidden" name="CurrentBillAmountForm.BillId" id="cbBillId" value="@Model.CurrentBillAmountForm.BillId" />

                    <div class="mb-3">
                        <label class="form-label">帳單金額</label>
                        <input class="form-control mono"
                               type="number"
