@page
@using System.Text.Json
@model GoldfishReminder.Api.Pages.IndexModel
@{
    Layout = null;
    var activeTab = Model.ActiveTab;
    var isBankTab = activeTab == "bankAccounts";
    var isCardTab = activeTab == "creditSettings";
    var isCurrentBillsTab = activeTab == "currentBills";
    var isHistoryBillsTab = activeTab == "historyBills";

    string GetAccountTypeText(string? accountType)
    {
        var normalized = (accountType ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            "digital" => "數位帳戶",
            "physical" => "實體帳戶",
            _ => accountType ?? string.Empty
        };
    }

    string GetBankDisplayName(string bankCode, string bankName)
    {
        return string.IsNullOrWhiteSpace(bankName) ? bankCode : $"{bankCode} {bankName}";
    }

    var enabledAccounts = Model.BankAccounts.Where(x => x.Enabled).ToList();
    var disabledAccounts = Model.BankAccounts.Where(x => !x.Enabled).ToList();
    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };
    var impactJson = JsonSerializer.Serialize(Model.BankAccountImpacts, jsonOptions);
    var historyYears = Model.HistoryMonthOptions
        .Select(x => x.Year)
        .Distinct()
        .OrderByDescending(x => x)
        .ToList();
    var historyMonths = Model.HistoryMonthOptions
        .Where(x => x.Year == Model.HistoryYear)
        .Select(x => x.Month)
        .Distinct()
        .OrderByDescending(x => x)
        .ToList();
    var historyMonthMap = Model.HistoryMonthOptions
        .GroupBy(x => x.Year)
        .ToDictionary(
            x => x.Key,
            x => x.Select(y => y.Month).Distinct().OrderByDescending(y => y).ToList());
    var historyMonthMapJson = JsonSerializer.Serialize(historyMonthMap, jsonOptions);
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>金魚腦助手</title>
    <meta name="description" content="信用卡帳單提醒服務 透過 Discord 通知 不串接銀行 你自己掌握資料" />
    <meta name="theme-color" content="#B85423" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32.png" />
    <link rel="canonical" href="https://goldfish-reminder.duckdns.org/" />
    <meta property="og:title" content="金魚腦助手 GoldfishReminder" />
    <meta property="og:description" content="信用卡帳單提醒服務 透過 Discord 通知 不串接銀行" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://goldfish-reminder.duckdns.org/" />
    <meta property="og:image" content="https://goldfish-reminder.duckdns.org/logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=Noto+Serif+TC:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/brand.css" asp-append-version="true" />
    <style>
        .card { border: 0; border-radius: 14px; }
        .shadow-soft { box-shadow: 0 10px 30px rgba(16, 24, 40, .08); }
        .muted { color: #667085; }
        .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
        .table thead th { color: #475467; font-weight: 600; }
        .badge-soft { background: #f2f4f7; border: 1px solid #eaecf0; color: #344054; }
        .impact-box { border: 1px solid #f0dca2; background: #fff8e6; border-radius: 12px; padding: 12px; }
        .impact-detail-list { margin-bottom: 0; padding-left: 18px; }
        .history-filter-form { max-width: 460px; }

        .gf-hero { background: radial-gradient(circle at 90% 20%, rgba(230,139,83,.20), transparent 60%), radial-gradient(circle at 10% 80%, rgba(196,99,42,.10), transparent 60%), linear-gradient(180deg,#FAF1E0 0%, #F4E5C9 60%, #FBF6EB 100%); color: var(--ink-text); padding: 80px 0 96px; position: relative; margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); margin-top: -1.5rem; overflow: hidden; }
        .gf-hero-eb { color: var(--gold); font-size: 11px; letter-spacing: .4em; font-weight: 600; margin-bottom: 18px; }
        .gf-hero h1 { font-family: 'Noto Serif TC', serif; font-size: clamp(22px, 1rem + 3.5vw, 56px); font-weight: 700; line-height: 1.15; margin: 0 0 18px; letter-spacing: -.01em; color: var(--ink-text); }
        .gf-hero h1 .accent { color: var(--gold); }
        .gf-hero-sub { color: var(--muted-color); font-size: 16px; line-height: 1.7; max-width: 480px; margin-bottom: 32px; }
        .gf-hero-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--gold); color: #fff; border: 0; border-radius: 10px; padding: 14px 26px; font-weight: 600; font-size: 14px; text-decoration: none; transition: .15s; }
        .gf-hero-cta:hover { background: var(--gold-dark); }
        .gf-hero-cta-ghost { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--ink-text); border: 1px solid rgba(0,0,0,.18); border-radius: 10px; padding: 14px 22px; font-weight: 500; font-size: 14px; text-decoration: none; margin-left: 8px; transition: .15s; }
        .gf-hero-cta-ghost:hover { border-color: var(--gold); color: var(--gold); }
        .gf-hero-mascot img { width: 100%; max-width: 380px; filter: drop-shadow(0 30px 60px rgba(255,138,74,.35)); }
        .gf-section-eb { color: var(--gold); font-size: 11px; letter-spacing: .3em; font-weight: 600; text-transform: uppercase; margin-bottom: 12px; }
        .gf-section-title { font-family: 'Noto Serif TC', serif; font-size: 32px; font-weight: 700; color: var(--ink-text); margin-bottom: 14px; }
        .gf-section-sub { color: var(--muted-color); font-size: 15px; max-width: 600px; }
        .gf-features { padding: 64px 0; background: var(--bg); margin-top: 24px; }
        .gf-feature { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px 28px; height: 100%; transition: .2s; }
        .gf-feature:hover { border-color: var(--gold-light); box-shadow: 0 12px 40px rgba(181,138,42,.08); transform: translateY(-2px); }
        .gf-feature-num { font-family: 'Noto Serif TC', serif; font-size: 14px; color: var(--gold); font-weight: 700; letter-spacing: .15em; margin-bottom: 20px; }
        .gf-feature-icon { width: 44px; height: 44px; color: var(--gold); margin-bottom: 18px; display: flex; align-items: center; justify-content: center; }
        .gf-feature-icon svg { width: 100%; height: 100%; stroke-width: 1.5; }
        .gf-feature h3 { font-family: 'Noto Serif TC', serif; font-size: 19px; font-weight: 600; margin: 0 0 10px; }
        .gf-feature p { color: var(--muted-color); font-size: 13.5px; line-height: 1.7; margin: 0; }
        .gf-steps { padding: 80px 0 64px; background: var(--bg); margin-top: 32px; border-top: 2px solid rgba(184, 84, 35, 0.15); }
        .gf-step { display: flex; gap: 20px; padding: 24px 0; border-bottom: 1px solid var(--border); }
        .gf-step:last-child { border-bottom: 0; }
        .gf-step-num { font-family: 'Noto Serif TC', serif; font-size: 32px; font-weight: 700; color: var(--gold); min-width: 60px; line-height: 1; letter-spacing: -.02em; }
        .gf-step h4 { font-family: 'Noto Serif TC', serif; font-size: 18px; font-weight: 600; margin: 0 0 6px; }
        .gf-step p { color: var(--muted-color); font-size: 14px; margin: 0; line-height: 1.7; }
        .gf-disclaimer { background: var(--gold-bg); border: 1px solid var(--border); border-radius: 12px; padding: 18px 22px; color: var(--tan); font-size: 12.5px; line-height: 1.7; display: flex; gap: 12px; align-items: flex-start; margin-top: 32px; }
        .gf-disclaimer-mark { color: var(--gold); font-family: 'Noto Serif TC', serif; font-weight: 700; font-size: 16px; line-height: 1.4; }

        /* === Hero CTA 鍵盤聚焦樣式 === */
        /* 舊瀏覽器 ( :focus-visible 不支援 ) 會落到第一條 click 與鍵盤都顯示 outline */
        /* 現代瀏覽器第二條會在點擊時抑制 outline 只在鍵盤聚焦顯示 */
        .gf-hero-cta:focus,
        .gf-hero-cta-ghost:focus {
            outline: 2px solid var(--gold);
            outline-offset: 2px;
        }
        .gf-hero-cta:focus:not(:focus-visible),
        .gf-hero-cta-ghost:focus:not(:focus-visible) {
            outline: none;
        }

        /* === 偏好減少動作的使用者關閉 transition / hover 位移 === */
        @@media (prefers-reduced-motion: reduce) {
            .gf-feature,
            .gf-feature:hover,
            .gf-hero-cta,
            .gf-hero-cta-ghost {
                transition: none;
                transform: none;
            }
        }

        /* === Mobile 響應式 配合 100vw bleed hero === */
        @@media (max-width: 768px) {
            .gf-hero { padding: 56px 0 64px; }
            .gf-hero-sub { font-size: 14px; }
            .gf-hero-cta, .gf-hero-cta-ghost { padding: 12px 18px; font-size: 13px; }
            .gf-hero-cta-ghost { margin-left: 0; margin-top: 8px; }
            .gf-features { padding: 48px 0; }
            .gf-steps { padding: 64px 0 48px; }
            .gf-section-title { font-size: 24px; }
            .gf-feature { padding: 24px 20px; }
            .gf-step { padding: 18px 0; }
            .gf-step-num { font-size: 26px; min-width: 44px; }
        }

        /* === Flex gap fallback 舊 Safari < 14.1 不支援 flex gap 用 margin 模擬 === */
        @@supports not (gap: 1px) {
            .gf-hero-cta > * + *,
            .gf-hero-cta-ghost > * + * { margin-left: 8px; }
            .gf-step > * + * { margin-left: 20px; }
            .gf-disclaimer > * + * { margin-left: 12px; }
        }
    </style>
</head>
<body>
<a href="#main" class="skip-link">跳至主要內容</a>
<nav class="gf-nav">
    <div class="container">
        <a class="gf-brand" href="/">
            <img src="~/logo.png" alt="金魚腦助手" />
            <div>
                <div class="gf-brand-zh">金魚腦助手</div>
                <div class="gf-brand-en">GOLDFISH REMINDER</div>
            </div>
        </a>
    </div>
</nav>

<main id="main" class="container py-4">
    @if (Model.ShowLanding)
    {
        <section class="gf-hero">
            <div class="container">
                <div class="row align-items-center g-3 g-md-5">
                    <div class="col-7">
                        <div class="gf-hero-eb">PERSONAL BILL REMINDER</div>
                        <h1>讓信用卡帳單<br /><span class="accent">不再被忘記</span></h1>
                        <p class="gf-hero-sub">幫你記住每張信用卡的結帳日、繳款日與扣款帳戶餘額，時間到了在 Discord 提醒你。不串接銀行，你的錢還是你自己掌握。</p>
                        <a href="mailto:goldfish-reminder.rotunda599@silomails.com?subject=申請使用金魚腦助手" class="gf-hero-cta">申請使用</a>
                        <a href="#features" class="gf-hero-cta-ghost">了解更多</a>
                        <p style="margin-top:14px; font-size:12px; color:var(--muted-color);">目前未對外開放，歡迎來信索取 DC 伺服器邀請</p>
                    </div>
                    <div class="col-5">
                        <div class="gf-hero-mascot text-center">
                            <img src="~/logo.png" alt="金魚腦助手吉祥物" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="gf-features" id="features">
            <div class="container">
                <div class="row mb-5">
                    <div class="col-lg-7">
                        <div class="gf-section-eb">CORE FEATURES · 核心功能</div>
                        <h2 class="gf-section-title">該繳費了、餘額不夠了，<br>金魚腦助手都會提醒你</h2>
                        <p class="gf-section-sub">記不住跟信用卡有關的所有日期與金額？交給金魚腦助手就好。</p>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-6 col-lg-4"><div class="gf-feature"><div class="gf-feature-num">01</div><div class="gf-feature-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg></div><h3>結帳日提醒</h3><p>結帳日當天提醒你去銀行 App 查本期帳單金額，點按鈕填入。</p></div></div>
                    <div class="col-md-6 col-lg-4"><div class="gf-feature"><div class="gf-feature-num">02</div><div class="gf-feature-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M16 7H10a3 3 0 0 0 0 6h4a3 3 0 0 1 0 6H7"/></svg></div><h3>餘額不足提醒</h3><p>扣款帳戶餘額不夠繳這期帳單時，提醒你該轉錢進去了。</p></div></div>
                    <div class="col-md-6 col-lg-4"><div class="gf-feature"><div class="gf-feature-num">03</div><div class="gf-feature-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-12"/><circle cx="5" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg></div><h3>未設定自動扣繳提醒</h3><p>沒有設定自動扣繳的信用卡，繳款日前會主動提醒你記得去繳款。</p></div></div>
                    <div class="col-md-6 col-lg-4"><div class="gf-feature"><div class="gf-feature-num">04</div><div class="gf-feature-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-7l-4 4v-4H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/><path d="M8 10h8M8 13h5"/></svg></div><h3>Discord 快速更新餘額</h3><p>錢轉完了，在 Discord 輸入 /balance 就能更新餘額，不用再開網頁。</p></div></div>
                    <div class="col-md-6 col-lg-4"><div class="gf-feature"><div class="gf-feature-num">05</div><div class="gf-feature-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8M12 18v3"/></svg></div><h3>一頁資料一目了然</h3><p>銀行帳戶、信用卡、本月與歷史帳單，都在同一個網頁後台管理。</p></div></div>
                </div>
            </div>
        </section>

        <section class="gf-steps">
            <div class="container">
                <div class="row mb-4">
                    <div class="col-lg-7">
                        <div class="gf-section-eb">HOW IT WORKS · 使用流程</div>
                        <h2 class="gf-section-title">四個步驟就能開始用</h2>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-9">
                        <div class="gf-step"><div class="gf-step-num">01</div><div><h4>在 Discord 伺服器取得網頁連結</h4><p>在公告頻道點「取得網頁連結」按鈕，Bot 會在私訊頻道傳給你一個專屬連結。</p></div></div>
                        <div class="gf-step"><div class="gf-step-num">02</div><div><h4>點連結進入網頁</h4><p>不需註冊、不需設密碼，點進去就可以開始設定。連結使用過或過期後，重新取得即可。</p></div></div>
                        <div class="gf-step"><div class="gf-step-num">03</div><div><h4>設定帳戶與信用卡</h4><p>填入銀行帳戶的目前餘額，以及每張信用卡的結帳日、繳款日與扣款帳戶。</p></div></div>
                        <div class="gf-step"><div class="gf-step-num">04</div><div><h4>等提醒，並定期更新餘額</h4><p>時間到了，金魚腦助手會在 Discord 提醒你。繳款日過後系統會自動扣除帳單金額，實際餘額請記得回來更新。</p></div></div>
                        <div class="gf-disclaimer"><span class="gf-disclaimer-mark">＊</span><div>本服務未串接任何銀行或金融機構，不會讀取也不會儲存你的銀行資料。所有帳戶餘額、帳單金額皆由你自行填入，僅供個人記帳與提醒使用。</div></div>
                    </div>
                </div>
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        @if (!string.IsNullOrWhiteSpace(Model.AlertMessage))
        {
            <div class="alert alert-info shadow-soft" role="alert">@Model.AlertMessage</div>
        }
        <div class="alert alert-danger shadow-soft" role="alert">
            <div class="fw-semibold mb-1">無法載入頁面</div>
            <div class="muted">@Model.ErrorMessage</div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(Model.AlertMessage))
        {
            <div class="alert alert-info shadow-soft" role="alert">@Model.AlertMessage</div>
        }
        <div class="row g-3">
            <div class="col-12">
                <div class="card shadow-soft">
                    <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <div class="fw-semibold fs-5">設定中心</div>
                            <div class="muted">管理銀行帳戶 信用卡設定 本月待繳帳單 歷史帳單</div>
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-primary" href="/?tab=@activeTab&historyYear=@Model.HistoryYear&historyMonth=@Model.HistoryMonth">重新整理</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-soft">
                    <div class="card-body">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item"><a class="nav-link @(isBankTab ? "active" : "")" href="/?tab=bankAccounts&historyYear=@Model.HistoryYear&historyMonth=@Model.HistoryMonth">帳戶設定</a></li>
                            <li class="nav-item"><a class="nav-link @(isCardTab ? "active" : "")" href="/?tab=creditSettings&historyYear=@Model.HistoryYear&historyMonth=@Model.HistoryMonth">信用卡設定</a></li>
                            <li class="nav-item"><a class="nav-link @(isCurrentBillsTab ? "active" : "")" href="/?tab=currentBills&historyYear=@Model.HistoryYear&historyMonth=@Model.HistoryMonth">本月待繳帳單</a></li>
                            <li class="nav-item"><a class="nav-link @(isHistoryBillsTab ? "active" : "")" href="/?tab=historyBills&historyYear=@Model.HistoryYear&historyMonth=@Model.HistoryMonth">歷史帳單</a></li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade @(isBankTab ? "show active" : "")">
                                <div class="mt-3 card shadow-soft">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="fw-semibold">啟用中銀行帳戶</div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="muted small">@enabledAccounts.Count 筆</span>
                                                <button class="btn btn-sm btn-primary" type="button" id="btnAddBankAccount" data-bs-toggle="modal" data-bs-target="#bankAccountModal">+ 新增</button>
                                            </div>
                                        </div>
                                        @if (enabledAccounts.Count == 0)
                                        {
                                            <div class="alert alert-warning mb-0">尚未有啟用中的銀行帳戶</div>
                                        }
                                        else
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th>銀行代碼</th>
                                                            <th>帳戶名稱</th>
                                                            <th>帳戶類型</th>
                                                            <th class="text-end">餘額</th>
                                                            <th class="text-center">操作</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    @foreach (var bankAccount in enabledAccounts)
                                                    {
                                                        <tr>
                                                            <td class="mono">@bankAccount.BankCode</td>
                                                            <td>@bankAccount.AccountName</td>
                                                            <td>@GetAccountTypeText(bankAccount.AccountType)</td>
                                                            <td class="text-end mono">@bankAccount.Balance.ToString("N0")</td>
                                                            <td class="text-center">
                                                                <button class="btn btn-sm btn-outline-primary"
                                                                        type="button"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#bankAccountModal"
                                                                        data-id="@bankAccount.Id"
                                                                        data-bankcode="@bankAccount.BankCode"
                                                                        data-accountname="@bankAccount.AccountName"
                                                                        data-accounttype="@bankAccount.AccountType"
                                                                        data-enabled="@bankAccount.Enabled">
                                                                    編輯
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }

                                        <hr class="my-4" />

                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="fw-semibold">停用中的銀行帳戶</div>
                                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#disabledAccountsCollapse">展開 (@disabledAccounts.Count)</button>
                                        </div>

                                        <div class="collapse mt-3" id="disabledAccountsCollapse">
                                            @if (disabledAccounts.Count == 0)
                                            {
                                                <div class="muted">目前沒有停用中的銀行帳戶</div>
                                            }
                                            else
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm align-middle">
                                                        <thead>
                                                            <tr>
                                                                <th>銀行代碼</th>
                                                                <th>帳戶名稱</th>
                                                                <th>帳戶類型</th>
                                                                <th class="text-end">餘額</th>
                                                                <th class="text-center">操作</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                        @foreach (var bankAccount in disabledAccounts)
                                                        {
                                                            <tr>
                                                                <td class="mono">@bankAccount.BankCode</td>
                                                                <td>@bankAccount.AccountName</td>
                                                                <td>@GetAccountTypeText(bankAccount.AccountType)</td>
                                                                <td class="text-end mono">@bankAccount.Balance.ToString("N0")</td>
                                                                <td class="text-center">
                                                                    <button class="btn btn-sm btn-outline-primary"
                                                                            type="button"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#bankAccountModal"
                                                                            data-id="@bankAccount.Id"
                                                                            data-bankcode="@bankAccount.BankCode"
                                                                            data-accountname="@bankAccount.AccountName"
                                                                            data-accounttype="@bankAccount.AccountType"
                                                                            data-enabled="@bankAccount.Enabled">
                                                                        編輯
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade @(isCardTab ? "show active" : "")">
                                <div class="mt-3 card shadow-soft">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="fw-semibold">信用卡設定清單</div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="muted small">@Model.CreditSettings.Count 筆</span>
                                                <button class="btn btn-sm btn-primary" type="button" id="btnAddCreditSetting" data-bs-toggle="modal" data-bs-target="#creditSettingModal">+ 新增</button>
                                            </div>
                                        </div>
                                        @if (Model.CreditSettings.Count == 0)
                                        {
                                            <div class="alert alert-warning mb-0">尚未有信用卡設定</div>
                                        }
                                        else
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th>銀行代碼</th>
                                                            <th>銀行名稱</th>
                                                            <th>結帳日</th>
                                                            <th>繳費日</th>
                                                            <th>扣款帳戶</th>
                                                            <th class="text-center">啟用</th>
                                                            <th class="text-center">操作</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    @foreach (var creditSetting in Model.CreditSettings)
                                                    {
                                                        var bankName = Model.BankNameByCode.TryGetValue(creditSetting.BankCode, out var bn) ? bn : string.Empty;
                                                        <tr>
                                                            <td class="mono">@creditSetting.BankCode</td>
                                                            <td>@(string.IsNullOrWhiteSpace(bankName) ? "-" : bankName)</td>
                                                            <td class="mono">@creditSetting.StatementDay</td>
                                                            <td class="mono">@creditSetting.PaymentDueDay</td>
                                                            <td>
                                                                @if (creditSetting.PaymentBankAccountId.HasValue && Model.PaymentAccountNameById.TryGetValue(creditSetting.PaymentBankAccountId.Value, out var paymentName))
                                                                {
                                                                    <span>@paymentName</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="muted">未設定</span>
                                                                }
                                                            </td>
                                                            <td class="text-center">
                                                                @if (creditSetting.Enabled)
                                                                {
                                                                    <span class="badge text-bg-success">是</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge text-bg-secondary">否</span>
                                                                }
                                                            </td>
                                                            <td class="text-center">
                                                                <button class="btn btn-sm btn-outline-primary"
                                                                        type="button"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#creditSettingModal"
                                                                        data-id="@creditSetting.Id"
                                                                        data-bankcode="@creditSetting.BankCode"
                                                                        data-statementday="@creditSetting.StatementDay"
                                                                        data-paymentdueday="@creditSetting.PaymentDueDay"
                                                                        data-paymentaccountid="@(creditSetting.PaymentBankAccountId?.ToString() ?? "")"
                                                                        data-enabled="@creditSetting.Enabled">
                                                                    編輯
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade @(isCurrentBillsTab ? "show active" : "")">
                                <div class="mt-3 card shadow-soft">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="fw-semibold">本月待繳帳單</div>
                                            <span class="muted small">@Model.CurrentBills.Count 筆</span>
                                        </div>
                                        @if (Model.CurrentBills.Count == 0)
                                        {
                                            <div class="alert alert-success mb-0">本月沒有待繳帳單</div>
                                        }
                                        else
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th>銀行</th>
                                                            <th>年月</th>
                                                            <th>繳費日</th>
                                                            <th class="text-end">帳單金額</th>
                                                            <th>扣款帳戶</th>
                                                            <th class="text-center">狀態</th>
                                                            <th class="text-center">操作</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    @foreach (var currentBill in Model.CurrentBills)
                                                    {
                                                        <tr>
                                                            <td>@GetBankDisplayName(currentBill.BankCode, currentBill.BankName)</td>
                                                            <td class="mono">@currentBill.BillYear/@currentBill.BillMonth.ToString("D2")</td>
                                                            <td class="mono">@currentBill.BillMonth.ToString("D2")/@currentBill.PaymentDueDay.ToString("D2")</td>
                                                            <td class="text-end mono">
                                                                @if (currentBill.AmountConfirmed && currentBill.BillAmount.HasValue)
                                                                {
                                                                    @currentBill.BillAmount.Value.ToString("N0")
                                                                }
                                                                else
                                                                {
                                                                    <span class="muted">未確認</span>
                                                                }
                                                            </td>
                                                            <td>@(string.IsNullOrWhiteSpace(currentBill.PaymentAccountName) ? "未設定" : currentBill.PaymentAccountName)</td>
                                                            <td class="text-center">
                                                                @if (currentBill.Paid)
                                                                {
                                                                    <span class="badge text-bg-secondary">已繳費</span>
                                                                }
                                                                else if (!currentBill.AmountConfirmed)
                                                                {
                                                                    <span class="badge text-bg-warning">待輸入金額</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge text-bg-primary">待繳費</span>
                                                                }
                                                            </td>
                                                            <td class="text-center">
                                                                @if (!currentBill.Paid)
                                                                {
                                                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                                                        <button class="btn btn-sm btn-outline-primary"
                                                                                type="button"
                                                                                data-bs-toggle="modal"
                                                                                data-bs-target="#billAmountModal"
                                                                                data-billid="@currentBill.Id"
                                                                                data-billamount="@(currentBill.BillAmount ?? 0)">
                                                                            修改金額
                                                                        </button>
                                                                        @if (currentBill.AmountConfirmed && string.IsNullOrWhiteSpace(currentBill.PaymentAccountName))
                                                                        {
                                                                            <form method="post" asp-page="/Index" asp-page-handler="MarkBillPaid" class="d-inline">
                                                                                @Html.AntiForgeryToken()
                                                                                <input type="hidden" name="tab" value="currentBills" />
                                                                                <input type="hidden" name="historyYear" value="@Model.HistoryYear" />
                                                                                <input type="hidden" name="historyMonth" value="@Model.HistoryMonth" />
                                                                                <input type="hidden" name="billId" value="@currentBill.Id" />
                                                                                <button type="submit" class="btn btn-sm btn-outline-success">確認已繳費</button>
                                                                            </form>
                                                                        }
                                                                    </div>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade @(isHistoryBillsTab ? "show active" : "")">
                                <div class="mt-3 card shadow-soft">
                                    <div class="card-body">
                                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
                                            <div>
                                                <div class="fw-semibold">歷史帳單</div>
                                                <div class="muted small">可用年份與月份篩選</div>
                                            </div>
                                            <form method="get" class="history-filter-form d-flex gap-2">
                                                <input type="hidden" name="tab" value="historyBills" />
                                                <select class="form-select form-select-sm" name="historyYear" id="historyYearSelect">
                                                    @foreach (var year in historyYears)
                                                    {
                                                        <option value="@year" selected="@(year == Model.HistoryYear)">@year</option>
                                                    }
                                                </select>
                                                <select class="form-select form-select-sm" name="historyMonth" id="historyMonthSelect">
                                                    @foreach (var month in historyMonths)
                                                    {
                                                        <option value="@month" selected="@(month == Model.HistoryMonth)">@month.ToString("D2")</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-outline-primary">查詢</button>
                                            </form>
                                        </div>

                                        @if (Model.HistoryBills.Count == 0)
                                        {
                                            <div class="alert alert-warning mb-0">目前查無歷史帳單</div>
                                        }
                                        else
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th>銀行</th>
                                                            <th>年月</th>
                                                            <th class="text-end">帳單金額</th>
                                                            <th class="text-center">是否已繳費</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    @foreach (var historyBill in Model.HistoryBills)
                                                    {
                                                        <tr>
                                                            <td>@GetBankDisplayName(historyBill.BankCode, historyBill.BankName)</td>
                                                            <td class="mono">@historyBill.BillYear/@historyBill.BillMonth.ToString("D2")</td>
                                                            <td class="text-end mono">@(historyBill.BillAmount.HasValue ? historyBill.BillAmount.Value.ToString("N0") : "-")</td>
                                                            <td class="text-center">
                                                                @if (historyBill.Paid)
                                                                {
                                                                    <span class="badge text-bg-success">是</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge text-bg-secondary">否</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</main>

